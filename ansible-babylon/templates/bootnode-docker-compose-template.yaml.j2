version: "3.9"

services:
  bootnode:
    image: "ghcr.io/sarvalabs/moipod:{{ image_tag }}"
    stdin_open: true
    hostname: bootnode
    container_name: bootnode
    restart: "no"
    volumes:
      - "/home/{{ app_user }}/shared/bootnode:/data:rw"
    working_dir: /data
    network_mode: "host"
    logging:
      driver: "json-file"
      options:
        max-size: "250m"
        max-file: 10

    command: >
      bootnode --port {{ bootnode_port }} --store-path="./datastore"
      {% if bootnode_endpoint is defined and bootnode_endpoint|length > 0 %}
      --peer-list {{ bootnode_endpoint }}
      {% endif %}
