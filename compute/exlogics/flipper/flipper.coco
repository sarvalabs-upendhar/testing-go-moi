coco Flipper

state logic:
    value Bool

endpoint deploy Init():
    pass

endpoint deploy Seed(initial Bool):
    set(value: initial)

endpoint Get() -> (value Bool):
    observe value <- Logic.Flipper.value

endpoint dynamic Set(value Bool):
    set(value: value)

endpoint dynamic Toggle():
    mutate value <- Logic.Flipper.value:
        value = !value

function dynamic set(value Bool):
    mutate value -> Logic.Flipper.value