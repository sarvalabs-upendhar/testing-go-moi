coco Flipper

state persistent:
    value Bool

endpoint deploy Init():
    pass

endpoint deploy Seed(initial Bool):
    set(value: initial)

endpoint invoke readonly Get() -> (value Bool):
    observe value <- Flipper.value

endpoint invoke persistent Set(value Bool):
    set(value: value)

endpoint invoke persistent Toggle():
    mutate value <- Flipper.value:
        value = !value

func persistent set(value Bool):
    mutate value -> Flipper.value