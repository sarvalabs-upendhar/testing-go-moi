coco Answer

state logic:
    Answer U64

state actor:
    ActorAnswer U64

endpoint deploy Init():
    mutate 42 -> Answer.Logic.Answer

endpoint GetLogicAnswer() -> (logic_answer U64):
    observe logic_answer <- Answer.Logic.Answer

endpoint GetActorAnswer(actorId Identifier) -> (actor_answer U64):
    observe actor_answer <- Answer.Actor(actorId).ActorAnswer

endpoint dynamic SetActorAnswer(actorId Identifier, new_answer U64):
    mutate new_answer -> Answer.Actor(actorId).ActorAnswer
