coco answer

state logic:
    Answer U64

state actor:
    ActorAnswer U64

endpoint deploy Init():
    mutate 42 -> Logic.answer.Answer

endpoint GetLogicAnswer() -> (logic_answer U64):
    observe logic_answer <- Logic.answer.Answer

endpoint GetActorAnswer(actorId Identifier) -> (actor_answer U64):
    observe actor_answer <- Actor(actorId).answer.ActorAnswer

endpoint dynamic SetActorAnswer(actorId Identifier, new_answer U64):
    mutate new_answer -> Actor(actorId).answer.ActorAnswer
