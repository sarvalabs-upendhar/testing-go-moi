coco Toggler

state ephemeral:
    value Bool

endpoint enlist Init():
    pass

endpoint enlist Seed(initial Bool):
    set(value: initial)

endpoint invoke readonly Get() -> (value Bool):
    observe value <- Sender.Toggler.value
 
endpoint invoke ephemeral Set(value Bool):
    set(value: value)

endpoint invoke ephemeral Toggle():
    mutate value <- Sender.Toggler.value:
        value = !value

func ephemeral set(value Bool):
    mutate value -> Sender.Toggler.value