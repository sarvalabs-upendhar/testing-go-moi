coco Toggler

state actor:
    value Bool

endpoint enlist Init():
    pass

endpoint enlist Seed(initial Bool):
    set(value: initial)

endpoint Get() -> (value Bool):
    observe value <- Sender.Toggler.value
 
endpoint dynamic Set(value Bool):
    set(value: value)

endpoint dynamic Toggle():
    mutate value <- Sender.Toggler.value:
        value = !value

function dynamic set(value Bool):
    mutate value -> Sender.Toggler.value