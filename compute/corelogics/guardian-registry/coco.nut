[coco]
version = "0.3.1"

[module]
name = "GuardianRegistry"
version = "0.2.0"
license = "n/a"
repository = "https://github.com/sarvalabs/go-moi/compute/corelogics/guardian-registry"
authors = ""

[target]
os = "MOI"
arch = "PISA"

[target.moi]
format = "YAML"
output = "guardian"

[target.pisa]
format = "BIN"
